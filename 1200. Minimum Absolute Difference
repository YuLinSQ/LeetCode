class Solution(object):
    def minimumAbsDifference(self, arr):
        """
        :type arr: List[int]
        :rtype: List[List[int]]
        """
        arr.sort()
        diff = float("inf")
        res = []
        for i in range(len(arr)-1):
            if arr[i+1] - arr[i] < diff:
                diff = arr[i+1] - arr[i]
                res = [[arr[i], arr[i+1]]]
            elif arr[i+1] - arr[i] == diff:
                res.append([arr[i], arr[i+1]])
        return res
