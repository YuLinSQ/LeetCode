class Solution(object):
    def equalSubstring(self, s, t, maxCost):
        """
        :type s: str
        :type t: str
        :type maxCost: int
        :rtype: int
        """
        arr = []
        for i in range(len(s)):
            arr.append(abs(ord(s[i]) - ord(t[i])))
        j = 0
        temp = 0
        res = 0
        for i in range(len(arr)):
            temp+=arr[i]
            while temp>maxCost:
                temp-=arr[j]
                j+=1
            res = max(res, i-j+1)
        return res
