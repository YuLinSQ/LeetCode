class Solution(object):
    def smallestDivisor(self, nums, threshold):
        """
        :type nums: List[int]
        :type threshold: int
        :rtype: int
        """
        nums.sort()
        low = 1
        high = nums[-1]
        while high>=low:
            i = (high+low)//2
            add = 0
            for j in nums:
                temp = j//i
                if j%i != 0:
                    temp+=1
                add+=temp
            if add <= threshold:
                high = i-1
            else:
                low = i+1
        return low
