class Solution(object):
    def maximumSubarraySum(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        hm = {}
        if len(nums)<k:
            return 0
        temp = 0
        res = 0
        for c in range(k):
            if nums[c] not in hm:
                hm[nums[c]] = 0
            hm[nums[c]]+=1
            temp+=nums[c]
        if len(hm) == k:
            res = temp
        for i in range(len(nums)-k):
            j = i+k
            hm[nums[i]]-=1
            temp-=nums[i]
            if nums[j] not in hm:
                hm[nums[j]] = 0
            hm[nums[j]]+=1
            temp+=nums[j]
            if hm[nums[i]] == 0:
                hm.pop(nums[i])
            if len(hm) == k:
                res = max(res, temp)
        return res
