class Solution(object):
    def findMaxFish(self, grid):
        """
        :type grid: List[List[int]]
        :rtype: int
        """
        visit = set()
        fish = [0]

        def dfs(r,c):
            if r<0 or r==len(grid) or c<0 or c==len(grid[0]) or (r,c) in visit or grid[r][c] == 0:
                return
            visit.add((r,c))
            fish[0] += grid[r][c]
            dfs(r-1,c)
            dfs(r+1,c)
            dfs(r,c+1)
            dfs(r,c-1)

        res = 0
        for r in range(len(grid)):
            for c in range(len(grid[0])):
                if grid[r][c]!=0:
                    fish[0] = 0
                    dfs(r,c)
                    if fish[0]>res:
                        res = fish[0]
        return res
                
            
