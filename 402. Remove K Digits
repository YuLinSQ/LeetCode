class Solution(object):
    def removeKdigits(self, num, k):
        """
        :type num: str
        :type k: int
        :rtype: str
        """
        count = 0
        prev = 0
        s = []
        for i in num:
            while k>0 and s and i<s[-1]:
                s.pop()
                k-=1
            s.append(i)
        s = s[:len(s)-k]
        s = "".join(s)
        if s == "":
            return "0"
        return str(int(s))
