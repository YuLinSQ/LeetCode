class Solution(object):
    def compress(self, chars):
        """
        :type chars: List[str]
        :rtype: int
        """
        if not chars:
            return 
        temp = chars[0]
        count = 1
        chars.append(None)
        ind = 0
        for i in range(1, len(chars)):
            if temp != chars[i]:
                chars[ind] = temp
                ind+=1
                if count>1:
                    count = str(count)
                    for j in count:
                        chars[ind] = j
                        ind+=1
                count = 1
                temp = chars[i]
            else:
                count+=1
        chars = chars[:ind]
        return len(chars)
