class Solution(object):
    def findContentChildren(self, g, s):
        """
        :type g: List[int]
        :type s: List[int]
        :rtype: int
        """
        g.sort()
        s.sort()
        ans = 0
        j = 0
        for i in g:
            while j != len(s) and s[j] < i:
                j+=1
            if j == len(s):
                return ans
            ans+=1
            j+=1
        return ans
                
        
