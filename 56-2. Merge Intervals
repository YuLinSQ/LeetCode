class Solution(object):
    def merge(self, intervals):
        """
        :type intervals: List[List[int]]
        :rtype: List[List[int]]
        """
        intervals.sort()
        ans = []
        low, high = intervals[0][0], intervals[0][1]
        for i in intervals:
            if (i[0]>=low and i[0]<=high) or (i[1]>=low and i[1]<=high):
                low = min(low, i[0])
                high = max(high, i[1])
            else:
                ans.append([low, high])
                low, high = i[0], i[1]
        if ans == []:
            ans.append([low, high])
        elif high != ans[-1][1]:
            ans.append([low, high])
        return ans
