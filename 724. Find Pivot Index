class Solution(object):
    def pivotIndex(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        s = 0
        for i in nums:
            s+=i
        temp = 0
        for i in range(len(nums)):
            if (s-nums[i])%2==0:
                if temp == (s-nums[i])//2:
                    return i
            temp+=nums[i]
        return -1
