class Solution(object):
    def searchMatrix(self, matrix, target):
        """
        :type matrix: List[List[int]]
        :type target: int
        :rtype: bool
        """
        if target < matrix[0][0]:
            return False
        if target > matrix[-1][-1]:
            return False
        i = 0
        j = len(matrix)-1
        while i<j-1:
            temp = (i+j)//2
            if matrix[temp][0]>target:
                j = temp-1
            elif matrix[temp][0]==target:
                return True
            else:
                i = temp
        if matrix[j][0] == target:
            return True
        if matrix[j][0] < target:
            i = j
        r = i
        i, j = 0,len(matrix[0])-1
        while i<j-1:
            temp = (i+j)//2
            if matrix[r][temp]>target:
                j = temp-1
            elif matrix[r][temp]==target:
                return True
            else:
                i = temp+1
        if i<len(matrix[0]) and matrix[r][i]==target:
            return True
        if j>0 and matrix[r][j]==target:
            return True
        return False
        
