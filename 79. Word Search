class Solution(object):
    def exist(self, board, word):
        """
        :type board: List[List[str]]
        :type word: str
        :rtype: bool
        """
        visit = {}

        def dfs(i, j, k):
            if board[i][j] != word[k] or (i,j) in visit:
                return False
            if k == len(word)-1 and board[i][j] == word[k]:
                return True
            visit[i,j] = 1
            if i != 0:
                if dfs(i-1,j,k+1):
                    return True
            if j != 0:
                if dfs(i,j-1,k+1):
                    return True
            if i != len(board)-1:
                if dfs(i+1,j,k+1):
                    return True
            if j != len(board[0])-1:
                if dfs(i,j+1,k+1):
                    return True
            visit.pop((i,j))
            return False

        for r in range(len(board)):
            for c in range(len(board[0])):
                if dfs(r,c,0):
                    return True
        return False
